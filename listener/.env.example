# The agent's IP address on the local network (find with: ifconfig | grep inet)
AGENT_URL=http://192.168.1.100:3456

# Shared secret (must match the agent's LISTENER_SECRET)
LISTENER_SECRET=nudge-demo-2026

# Teri's phone number (so the agent knows who these messages belong to)
OWNER_PHONE=+1XXXXXXXXXX

# Chat IDs to ignore (the agent's chat — don't forward messages Teri sends to Nudge)
IGNORE_CHAT_IDS=+16267221956
